{
  "name": "ff-test-firefox-bidi-client",
  "version": "0.2.0",
  "description": "Pure WebDriver BiDi client for Firefox automation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "bin": {
    "ff-bidi-run": "bin/ff-bidi-run.mjs"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "firefox",
    "webdriver",
    "bidi",
    "webdriver-bidi",
    "browser-automation",
    "automation",
    "testing"
  ],
  "author": "Mozilla",
  "license": "MIT OR Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@puppeteer/browsers": "^3.0.6",
    "chromium-bidi": "^16.0.1",
    "devtools-protocol": "^0.0.1654583",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.1.4",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3",
    "vitest": "^3.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/juliandescottes/firefox-bidi-client.git"
  }
}
